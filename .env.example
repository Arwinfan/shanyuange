# 应用环境
# 本地开发使用 development；生产环境请设置 production。
APP_ENV=development

# 本地开发允许在 D1 未绑定时回退内存 Mock。
# 生产环境必须设置为 false，并确保 Cloudflare Pages 已绑定 D1。
ALLOW_MOCK_DB=true

# 本地支付确认入口，仅限 development 或显式开启。
# 生产环境必须设置为 false，并接入真实支付渠道与回调验签。
MOCK_PAYMENT=true
PAYMENT_PROVIDER=local

# 本地短信验证码，仅限 development。
# 开发阶段验证码固定为 123456；生产环境必须设置为 false 并接入真实短信服务商。
MOCK_SMS=true
MOCK_SMS_CODE=123456

# 大模型接入（OpenAI 兼容 Chat Completions）
# Next 本地脚本可复制为 .env.local；Cloudflare Pages Functions 本地开发可复制为 .dev.vars。
# Cloudflare Pages 生产环境请在控制台或 wrangler secrets 中配置。
LLM_API_KEY=
LLM_MODEL=agnes-2.0-flash
LLM_IMAGE_MODEL=agnes-image-2.1-flash
LLM_BASE_URL=https://apihub.agnes-ai.com/v1
AI_ENABLED=true
AI_PROVIDER=agnes
AI_API_KEY=
AI_MODEL=agnes-2.0-flash
AI_BASE_URL=https://apihub.agnes-ai.com/v1
AI_TIMEOUT_MS=30000

# 如图像模型使用不同网关，可单独覆盖；默认复用 LLM_BASE_URL。
# LLM_IMAGE_BASE_URL=https://apihub.agnes-ai.com/v1

# 也兼容以下 OpenAI 风格变量名：
# OPENAI_API_KEY=
# OPENAI_MODEL=
# OPENAI_IMAGE_MODEL=
# OPENAI_BASE_URL=https://api.openai.com/v1

# 反馈管理页访问密钥，仅在服务端配置，勿提交真实生产密钥
ADMIN_ACCESS_KEY=replace-with-a-strong-admin-key
# 全站 15 天试运营：在正式上线当天填写 ISO 时间，所有用户共享同一个免费窗口
SITE_TRIAL_START_AT=
SITE_TRIAL_DAYS=15