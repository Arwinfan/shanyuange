{
  "name": "putiyuan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-full.mjs",
    "dev:web": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:functions": "npx --yes wrangler pages dev .next --port 8788 --proxy 3000",
    "dev:full": "node scripts/dev-full.mjs",
    "build": "next build",
    "start": "next start",
    "test:smoke": "node scripts/smoke.mjs",
    "db:init": "npx --yes wrangler d1 execute putiyuan-db --local --file=./db/schema.sql",
    "db:seed": "npx --yes wrangler d1 execute putiyuan-db --local --file=./db/seed.sql",
    "pages:dev": "npx --yes wrangler pages dev .next --port 8788",
    "pages:deploy": "npx --yes wrangler pages deploy .next",
    "api:tencent": "tsx server/tencent-api.ts",
    "api:tencent:watch": "tsx watch server/tencent-api.ts"
  },
  "dependencies": {
    "cos-nodejs-sdk-v5": "^3.0.0",
    "jsqr": "^1.4.0",
    "lunar-javascript": "^1.7.7",
    "mysql2": "^3.23.1",
    "next": "16.2.9",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
